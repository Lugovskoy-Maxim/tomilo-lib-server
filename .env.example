FRONTEND_URL=https://tomilo-lib.ru
PORT=3001
MONGO_LOGIN=admin
MONGO_PASSWORD=password123
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_AUTHDATABASE=admin
MONGO_DATABASE=tomilo-lib_db
# Каталог для бэкапов БД (JSON по коллекциям). По умолчанию ./backups
# BACKUP_DIR=/var/backups/tomilo-db
# Ежедневная отправка архива на почту (cron в приложении, 03:00 по времени сервера). Нужны YANDEX_EMAIL / YANDEX_PASSWORD и утилита tar в PATH.
BACKUP_EMAIL_ENABLED=false
BACKUP_EMAIL_TO=support@tomilo-lib.ru
# Лимит размера вложения (байт), по умолчанию ~24 МБ (лимит SMTP)
# BACKUP_EMAIL_MAX_BYTES=25165824
JWT_SECRET=your-super-secret-jwt-key

# Yandex OAuth
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# VK OAuth (старый oauth.vk.com)
VK_CLIENT_ID=your_vk_client_id
VK_CLIENT_SECRET=your_vk_client_secret
VK_REDIRECT_URI=http://localhost:3000/auth/vk/callback

# VK ID (id.vk.ru, OAuth 2.0 + PKCE)
VK_ID_CLIENT_ID=your_vk_id_client_id
VK_ID_REDIRECT_URI=http://localhost:3000/auth/vk-id/callback

# S3 Storage (Рег.Клауд или совместимое)
# Получите данные в панели Рег.облака: Хранилище S3 → Ключи доступа
S3_ENDPOINT=https://s3.regcloud.ru
S3_ACCESS_KEY_ID=your_access_key_id
S3_SECRET_ACCESS_KEY=your_secret_access_key
S3_BUCKET=your_bucket_name
S3_REGION=us-east-1
# Публичный URL для доступа к файлам (если отличается от endpoint)
S3_PUBLIC_URL=https://your_bucket_name.s3.regcloud.ru

# S3 Backup Configuration
# Использовать S3 для бекапов вместо отправки вложением по почте
BACKUP_USE_S3=true
# Префикс для хранения бекапов в S3 (например: backups/database)
BACKUP_S3_PREFIX=backups/database
# Автоматически очищать старые бекапы в S3
BACKUP_S3_CLEANUP_ENABLED=true
# Количество дней для хранения бекапов в S3
BACKUP_S3_DAYS_TO_KEEP=30

# Web Push (VAPID). Сгенерировать: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:support@tomilo-lib.ru
# URL фронта для ссылок в push-уведомлениях (по умолчанию FRONTEND_URL или https://tomilo-lib.ru)
SITE_URL=https://tomilo-lib.ru
